<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-regression.xml – Full regression suite with parallel execution.
  Run: mvn test -Pregression
-->
<suite name="Final Rental – Regression Suite" verbose="1" parallel="classes" thread-count="4">

    <listeners>
        <listener class-name="com.finalrental.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.finalrental.tests.HomePageTest"/>
            <class name="com.finalrental.tests.SearchResultsTest"/>
            <class name="com.finalrental.tests.DatePickerTest"/>
            <class name="com.finalrental.tests.PricingCalculationTest"/>
            <class name="com.finalrental.tests.BookingFlowTest"/>
            <class name="com.finalrental.tests.LoginTest"/>
        </classes>
    </test>

</suite>
